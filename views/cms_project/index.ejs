<!doctype html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Projects - CMS</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css">
    <%- include('../partials/header'); %>
</head>

<body class="auth-body flex-column align-items-stretch" style="padding-top: 80px;">
    <%- include('../partials/navcms'); %>
        <div class="container mt-5">
            <div class="glass-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="text-white m-0">Projects (Works)</h3>
                    <a class="btn btn-primary btn-gradient" href="/cms/project/create"><i class="fas fa-plus me-2"></i>
                        Add Project</a>
                </div>
                <div class="table-responsive">
                    <table class="table table-borderless text-white align-middle">
                        <thead style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                            <tr>
                                <th scope="col" class="text-muted pb-3">#</th>
                                <th scope="col" class="text-muted pb-3">Image</th>
                                <th scope="col" class="text-muted pb-3">Title</th>
                                <th scope="col" class="text-muted pb-3">Description</th>
                                <th width="200px" class="text-muted pb-3 text-end">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (projects && projects.length> 0) { %>
                                <% for(var i=0; i< projects.length; i++) { %>
                                    <tr style="border-bottom: 1px solid rgba(255,255,255,0.05);">
                                        <td class="py-3">
                                            <%= (i+1) %>
                                        </td>
                                        <td class="py-3">
                                            <% if (projects[i].image_url) { %>
                                                <img src="<%= projects[i].image_url %>"
                                                    style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;"
                                                    alt="img"
                                                    onerror="this.onerror=null; this.src='/assets/img/ksw.jpg';">
                                                <% } else { %>
                                                    <span class="text-muted small">No Image</span>
                                                    <% } %>
                                        </td>
                                        <td class="py-3 fw-bold">
                                            <%= projects[i].title%>
                                        </td>
                                        <td class="py-3 text-muted"
                                            style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                                            <%= projects[i].description%>
                                        </td>
                                        <td class="py-3 text-end">
                                            <a class="btn btn-sm btn-outline-info me-2 rounded-pill"
                                                href="/cms/project/update/<%=projects[i].id%>"><i
                                                    class="fas fa-edit"></i> Edit</a>
                                            <a class="btn btn-sm btn-outline-danger rounded-pill"
                                                onclick="return confirm('Are You sure you want to delete this?')"
                                                href="/cms/project/delete/<%=projects[i].id%>"><i
                                                    class="fas fa-trash"></i> Delete</a>
                                        </td>
                                    </tr>
                                    <% } %>
                                        <% } else { %>
                                            <tr>
                                                <td colspan="5" class="text-center py-5 text-muted">
                                                    <i class="fas fa-folder-open mb-3"
                                                        style="font-size: 2rem; opacity: 0.5;"></i><br>
                                                    No projects found. Try adding one!
                                                </td>
                                            </tr>
                                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.1/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>