<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Create Project</title>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0/css/bootstrap.min.css" />
    <%- include('../partials/header'); %>
</head>

<body class="auth-body flex-column align-items-stretch" style="padding-top: 80px">
    <%- include('../partials/navcms'); %>
        <div class="container mt-5">
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <div class="glass-card shadow-lg p-5">
                        <h3 class="text-white mb-4 fw-bold">Add New Project</h3>
                        <form action="/cms/project/create" method="post" enctype="multipart/form-data">
                            <div class="mb-3">
                                <label class="form-label text-white">Title</label>
                                <input type="text" class="form-control glass-input" name="title"
                                    placeholder="Project Title" required />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-white">Project URL</label>
                                <input type="url" class="form-control glass-input" name="project_url"
                                    placeholder="https://example.com" />
                            </div>
                            <div class="mb-3">
                                <label class="form-label text-white">Description</label>
                                <textarea class="form-control glass-input" name="description"
                                    placeholder="Project Description" rows="4" required></textarea>
                            </div>
                            <div class="mb-4">
                                <label class="form-label text-white">Cover Image</label>
                                <input type="file" class="form-control glass-input" name="image" accept="image/*" />
                                <small class="text-muted mt-2 d-block">Recommended size to fit properly in the
                                    cards.</small>
                            </div>
                            <div class="d-flex justify-content-between">
                                <a href="/cms/project" class="btn btn-outline-secondary rounded-pill px-4">Cancel</a>
                                <button type="submit" class="btn btn-primary btn-gradient px-4">Save Project</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.1/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>